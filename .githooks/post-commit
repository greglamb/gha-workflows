#!/usr/bin/env bash
# Tag the commit when package.json's version changed.
# Skips during rebase/cherry-pick/merge to avoid tag spam.
#
# Compares the version field between HEAD and HEAD~1 instead of diffing
# the file as a whole — this means amends that touched package.json but
# did not change the version (e.g. fixing a typo elsewhere in the file)
# are correctly skipped, while amends that change the version re-tag.
# If the tag already exists at a different commit (typical after amend),
# the tag is force-moved to HEAD; the original commit is being abandoned.

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
GIT_DIR="$(git rev-parse --git-dir)"

if [[ -d "$GIT_DIR/rebase-merge" || -d "$GIT_DIR/rebase-apply" || -f "$GIT_DIR/CHERRY_PICK_HEAD" || -f "$GIT_DIR/MERGE_HEAD" ]]; then
  exit 0
fi

if ! command -v jq >/dev/null 2>&1; then
  echo "post-commit: jq not installed, skipping tag" >&2
  exit 0
fi

PKG="$ROOT/package.json"
[[ -f "$PKG" ]] || exit 0

NEW_VERSION=$(jq -r '.version // empty' "$PKG")
[[ -n "$NEW_VERSION" ]] || exit 0

OLD_VERSION=""
if git rev-parse HEAD~1 >/dev/null 2>&1; then
  OLD_VERSION=$(git show "HEAD~1:package.json" 2>/dev/null | jq -r '.version // empty' 2>/dev/null || echo "")
fi

if [[ "$NEW_VERSION" == "$OLD_VERSION" ]]; then
  exit 0
fi

TAG="v$NEW_VERSION"
HEAD_SHA=$(git rev-parse HEAD)

if git rev-parse --verify --quiet "refs/tags/$TAG" >/dev/null; then
  EXISTING_SHA=$(git rev-list -n 1 "$TAG")
  if [[ "$EXISTING_SHA" == "$HEAD_SHA" ]]; then
    exit 0
  fi
  git tag -f "$TAG" HEAD
  echo "post-commit: moved tag $TAG from $EXISTING_SHA to HEAD (likely amend)"
  exit 0
fi

git tag "$TAG" HEAD
echo "post-commit: tagged $TAG"
